<footer class="bg-spruce text-navy py-12 mt-auto">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 items-center">
      <!-- Logo -->
      <div class="flex justify-center md:justify-start">
        <img src="/assets/images/logos/SpencerMills_Logo_WhiteOutline_NavyText.svg" alt="Spencer Mills OPC" class="h-16 w-auto">
      </div>

      <!-- Contact Info (Centered) -->
      <div class="text-center">
        <h3 class="font-display text-2xl text-white font-bold mb-4">Thank you for visiting.</h3>
        <p class="text-navy text-sm">
          {{ site.title }}<br>
          {{ site.address.street }}, {{ site.address.city }}, {{ site.address.state }} {{ site.address.zip }}<br>
          <a href="tel:{{ site.phone | remove: '.' }}" class="hover:text-navy/70 transition-colors">{{ site.phone }}</a>
        </p>
      </div>

      <!-- Social Media -->
      <div class="text-center md:text-right flex items-center justify-center md:justify-end gap-4">
        <a href="{{ site.social.facebook }}" target="_blank" rel="noopener noreferrer" class="flex items-center justify-center text-navy hover:text-navy/70 transition-colors" aria-label="Facebook">
          <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
          </svg>
        </a>
        <a href="https://www.youtube.com/@SpencerMillsChurch" target="_blank" rel="noopener noreferrer" class="flex items-center justify-center text-navy hover:text-navy/70 transition-colors" aria-label="YouTube">
          <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
          </svg>
        </a>
      </div>
    </div>
  </div>
</footer>
